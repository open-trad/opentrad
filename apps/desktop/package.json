    "better-sqlite3": "^12.9.0",
    "electron": "^41.3.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.11.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@opentrad/shared": "workspace:^",
